# ═══════════════════════════════════════════════════════════════════
# APERO Onboarding v2 — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# LOCAL DEV: copy file này thành .env. Có thể để TRỐNG hết — app sẽ
# dùng file .kv-local.json để lưu data ở local (persist qua restart).
#
# PRODUCTION (Vercel): Vercel auto-inject các env khi connect Blob storage.
# ═══════════════════════════════════════════════════════════════════

# ─── Storage (Vercel Blob) ───
# Auto-set khi tạo Blob store: Vercel Dashboard → Storage → Create → Blob
BLOB_READ_WRITE_TOKEN=

# ─── Cron Security (optional) ───
CRON_SECRET=

# ─── Auth (Google OAuth — chỉ chấp nhận @apero.vn) ───
# Tạo OAuth Client ID ở: https://console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth Client ID → Web application
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://apero-onboarding.vercel.app
GOOGLE_CLIENT_ID=

# Random string dài (32+ ký tự) để ký session cookie
# Tạo nhanh: openssl rand -hex 32
SESSION_SECRET=

# Domains cho phép, comma-separated. Default: apero.vn
ALLOWED_DOMAINS=apero.vn

# ─── Server (local only) ───
PORT=3000

# ═══════════════════════════════════════════════════════════════════
# SMTP (gửi email tự động) — KHÔNG cần set ở .env
# Cấu hình qua trang "Cài Đặt" trong app sau khi chạy. App lưu vào storage.
# ═══════════════════════════════════════════════════════════════════
