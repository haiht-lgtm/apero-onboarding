# ═══════════════════════════════════════════════════════════════════
# APERO Onboarding v2 — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# LOCAL DEV: copy file này thành .env. Có thể để TRỐNG hết — app sẽ
# dùng file .kv-local.json để lưu data ở local (persist qua restart).
#
# PRODUCTION (Vercel): set các env vars ở Vercel Dashboard → Settings → Environment.
# Khi connect Upstash Redis qua Vercel Marketplace, env vars Upstash
# được tự inject — không cần set thủ công.
# ═══════════════════════════════════════════════════════════════════

# ─── Storage (Upstash Redis qua Vercel Marketplace) ───
# Để TRỐNG ở local → app dùng file .kv-local.json
# Set trên Vercel sau khi cài Upstash Redis integration (auto-set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Backward compat (nếu Vercel inject env vars dạng KV_*)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Cron Security (optional) ───
# Nếu set, Vercel Cron phải gửi header "Authorization: Bearer {CRON_SECRET}"
CRON_SECRET=

# ─── Server ───
PORT=3000

# ═══════════════════════════════════════════════════════════════════
# SMTP (gửi email tự động) — KHÔNG cần set ở .env
# Cấu hình qua trang "Cài Đặt" trong app sau khi chạy. App lưu vào KV.
# ═══════════════════════════════════════════════════════════════════
